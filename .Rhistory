```
'
writeLines(vignette_content, "vignettes/fastrenameR.Rmd")
cat("Vignette creee\n")
if (!requireNamespace("knitr", quietly = TRUE)) install.packages("knitr")
if (!requireNamespace("rmarkdown", quietly = TRUE)) install.packages("rmarkdown")
devtools::build_vignettes()
# ================================================================
# FINALISATION DU PACKAGE APRÈS LA CRÉATION DE LA VIGNETTE
# ================================================================
# 1. Mettre à jour le DESCRIPTION avec VignetteBuilder
desc_content <- readLines("DESCRIPTION")
if (!any(grepl("VignetteBuilder", desc_content))) {
write("\nVignetteBuilder: knitr", file = "DESCRIPTION", append = TRUE)
cat("✓ VignetteBuilder ajouté au DESCRIPTION\n")
} else {
cat("✓ VignetteBuilder déjà présent\n")
}
# 2. S'assurer que knitr et rmarkdown sont dans Suggests
if (!any(grepl("knitr", desc_content)) || !any(grepl("rmarkdown", desc_content))) {
cat("Ajout de knitr et rmarkdown à Suggests...\n")
# Lire le fichier DESCRIPTION complet
desc_full <- readLines("DESCRIPTION")
# Trouver la ligne Suggests
suggests_line <- grep("^Suggests:", desc_full)
if (length(suggests_line) > 0) {
# Ajouter knitr et rmarkdown à la ligne Suggests existante
current_suggests <- desc_full[suggests_line]
if (!grepl("knitr", current_suggests)) {
desc_full[suggests_line] <- gsub("Suggests:", "Suggests: knitr,", current_suggests)
}
if (!grepl("rmarkdown", current_suggests)) {
desc_full[suggests_line] <- gsub("Suggests:", "Suggests: rmarkdown,", desc_full[suggests_line])
}
writeLines(desc_full, "DESCRIPTION")
} else {
# Ajouter une nouvelle ligne Suggests
write("\nSuggests: knitr, rmarkdown", file = "DESCRIPTION", append = TRUE)
}
cat("✓ Dépendances ajoutées\n")
}
# 3. Re-documenter
cat("\nRe-documentation du package...\n")
devtools::document()
# 4. Installer le package avec les vignettes
cat("\nInstallation du package avec vignettes...\n")
devtools::install(build_vignettes = TRUE)
# 5. Tester le chargement
cat("\nTest du chargement...\n")
library(fastrenameR)
cat("✓ Package chargé avec succès\n")
# 6. Tester la fonction standardize_dates
cat("\nTest de standardize_dates()...\n")
test_result <- standardize_dates(c("5-15-2024", "5-2024", "2024.5", "2024"))
cat("✓ Résultat:", paste(test_result, collapse = ", "), "\n")
# 7. Vérifier la vignette
cat("\nVérification de la vignette...\n")
vignette_list <- vignette(package = "fastrenameR")
if(length(vignette_list$results) > 0) {
cat("✓ Vignette disponible:", vignette_list$results[, "Title"], "\n")
} else {
cat("⚠ Aucune vignette trouvée\n")
}
# 8. Vérification complète du package
cat("\n==========================================\n")
cat("VÉRIFICATION COMPLÈTE DU PACKAGE\n")
cat("==========================================\n")
cat("Cette étape peut prendre quelques minutes...\n")
# Lancer le check sans certaines vérifications pour accélérer
check_result <- devtools::check(args = c("--no-manual", "--ignore-vignettes"))
# 9. Afficher le résumé
cat("\n==========================================\n")
cat("RÉSUMÉ FINAL\n")
cat("==========================================\n")
# Compter les erreurs, warnings et notes
check_file <- "00check.log"
if(file.exists("../../00check.log")) {
log_content <- readLines("../../00check.log")
errors <- sum(grepl("ERROR", log_content))
warnings <- sum(grepl("WARNING", log_content))
notes <- sum(grepl("NOTE", log_content))
cat("Résultats du check:\n")
cat("  - Erreurs:", errors, "\n")
cat("  - Warnings:", warnings, "\n")
cat("  - Notes:", notes, "\n")
if(errors == 0 && warnings == 0 && notes == 0) {
cat("\n🎉 PARFAIT! 0 erreurs, 0 warnings, 0 notes\n")
} else {
cat("\n⚠ Quelques issues à corriger\n")
}
} else {
cat("Check terminé. Vérifiez le rapport manuellement.\n")
}
cat("\n==========================================\n")
cat("COMMANDES POUR GITHUB\n")
cat("==========================================\n")
# 10. Option: Pousser sur GitHub
cat("\nVoulez-vous pousser sur GitHub? (o/n): ")
answer <- readline()
if(tolower(answer) == "o") {
cat("\n📤 Push sur GitHub...\n")
# Ajouter tous les fichiers
system("git add .")
# Commit
system('git commit -m "Version 0.2.0: Add date standardization and vignette"')
# Push
system("git push origin main")
# Créer et pousser le tag
system("git tag -a v0.2.0 -m 'Release v0.2.0: CRAN ready with vignette'")
system("git push origin v0.2.0")
cat("✓ Push sur GitHub terminé\n")
cat("✓ Tag v0.2.0 créé\n")
} else {
cat("\nPush ignoré. Pour le faire manuellement plus tard:\n")
cat("  git add .\n")
cat("  git commit -m 'Version 0.2.0: Add date standardization and vignette'\n")
cat("  git push origin main\n")
cat("  git tag -a v0.2.0 -m 'Release v0.2.0'\n")
cat("  git push origin v0.2.0\n")
}
cat("\n==========================================\n")
cat("COMMANDES POUR CRAN\n")
cat("==========================================\n")
cat("\nPour soumettre à CRAN (optionnel):\n")
cat("  devtools::submit_cran()\n")
cat("\nOu pour vérifier avant soumission:\n")
cat("  devtools::check(remote = TRUE, manual = TRUE)\n")
cat("  devtools::release()\n")
cat("\n🎉 FÉLICITATIONS! Package fastrenameR version 0.2.0 terminé!\n")
cat("📦 Package prêt à être utilisé et partagé!\n")
